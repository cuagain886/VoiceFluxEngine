# voicestream 环境变量模板
# ─────────────────────────────────────────────────────────────────────────────
# 用法：复制本文件为 .env 并填入真实值
#   PowerShell:  Copy-Item .env.example .env
#   bash/zsh:    cp .env.example .env
#
# ✅ 服务器启动会「自动读取」项目根目录的 .env（见 internal/config/dotenv.go）——
#    填好下面的值，直接 `go run ./cmd/server` 即可，无需手动 source。
#    已存在的真实环境变量优先，不会被 .env 覆盖。
#
# ⚠️ 安全：.env 含密钥，已被 .gitignore 忽略，切勿提交；配置文件里也绝不写明文 key。
#    本模板（.env.example）只放占位符，可安全入库。
# ─────────────────────────────────────────────────────────────────────────────

# ── 必填（仅当接真实云端 LLM 时）──────────────────────────────
# OpenAI 风格 chat-completions 端点的 API key。
# 变量名由配置项 adapters.cloud_llm.api_key_env 指定，默认就是下面这个。
# 本地模型（Ollama 等）无需鉴权，但适配器要求非空，填任意值即可，如 local。
VOICESTREAM_LLM_API_KEY=

# ── 选填：选择配置文件（填这里就不必每次敲 $env:VOICESTREAM_CONFIG）──────────
# 不设则全用内置默认（全 mock，监听 :8080，自带浏览器演示页）。
# VOICESTREAM_CONFIG=configs/sherpa.yaml

# ── 选填：覆盖少量高频项（优先级高于 YAML / 默认）────────────────
# VOICESTREAM_ADDR=:8080
# VOICESTREAM_SAMPLE_RATE=16000
# 设置即「自动开启」Redis 并指向该地址：
# VOICESTREAM_REDIS_ADDR=127.0.0.1:6379

# ── 仅用于 openaicompat 的「真连云」集成测试（go test，运行服务器不需要）──
# VOICESTREAM_LLM_BASE_URL=https://api.deepseek.com/v1
# VOICESTREAM_LLM_MODEL=deepseek-chat
